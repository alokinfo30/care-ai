# OpenRouter API Key - REQUIRED
OPENROUTER_API_KEY="sk-or-..."

# Comma-separated list of supported language codes
SUPPORTED_LANGUAGES="en,hi,es,fr,de,zh"

# Redis connection URL for background jobs
REDIS_URL="redis://localhost:6379/0"

# Server-side debounce interval in seconds for sensor jobs
DEBOUNCE_SECS=5